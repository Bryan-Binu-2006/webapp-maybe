# ============================================================================
# .env.example — Example environment variables
# ============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to version control.
#
#   cp .env.example .env
#   nano .env
# ============================================================================

# Flask environment: 'development' or 'production'
FLASK_ENV=development

# Secret key for signing session cookies.
# Generate a secure one:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://certapp:certapp@localhost:5432/certapp

# Where generated certificates are stored on disk
STORAGE_DIR=./storage

# Temporary upload directory
UPLOAD_DIR=./uploads

# Session timeout in minutes
SESSION_LIFETIME_MINUTES=30

# Set to True when serving over HTTPS
SESSION_COOKIE_SECURE=False

# Maximum certificates per batch
MAX_BATCH_SIZE=300

# Maximum name length in characters
MAX_NAME_LENGTH=120

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: path to a .ttf font file for certificate text
# CERTIFICATE_FONT=/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf
